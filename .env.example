# =============================================================
# SUPABASE
# =============================================================
# URL pública do projeto Supabase (segura para o frontend)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Chave anon pública (segura para o frontend — respeita RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Service role (NUNCA expor no frontend — apenas no servidor)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# =============================================================
# N8N
# =============================================================
# URL do webhook do n8n que recebe os dados do case
N8N_WEBHOOK_URL=https://n8n.example.com/webhook/cases

# Secret compartilhado entre este app e o n8n para autenticar callbacks
# Gere com: openssl rand -hex 32
N8N_CALLBACK_SECRET=sua_chave_secreta_aleatoria_aqui

# =============================================================
# FRAMER CMS
# =============================================================
# API Key gerada no painel do Framer (Settings > Integrations > API)
# ATENÇÃO: se esta chave foi exposta, gere uma nova imediatamente
FRAMER_API_KEY=framer_xxxxxxxxxxxxxxxx

# URL completa do projeto no Framer (copie direto da barra de endereço do editor)
# Formato: https://framer.com/projects/Nome-Do-Projeto--aabbccdd1122
FRAMER_PROJECT_URL=https://framer.com/projects/Seu-Projeto--aabbccdd1122

# Nome exato da collection no CMS do Framer
# Ajuste conforme o nome que você criou no Framer
FRAMER_COLLECTION_NAME=Cases
